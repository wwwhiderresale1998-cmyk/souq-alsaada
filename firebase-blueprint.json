{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string" },
        "phone": { "type": "string" },
        "capetel": { "type": "string" },
        "address": { "type": "string" }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/users/{email}": {
      "schema": "User",
      "description": "User profiles"
    }
  }
}
